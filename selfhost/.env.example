# ============================================================================
# Ycode lean self-host — environment
# Copy to .env and fill in. NEVER commit .env (it is gitignored).
# ============================================================================

# --- Secrets (generate all three together: `node gen-keys.mjs`) -------------
# JWT_SECRET is shared by GoTrue, PostgREST, Storage and Realtime.
# ANON_KEY / SERVICE_KEY are JWTs minted from JWT_SECRET.
JWT_SECRET=
ANON_KEY=
SERVICE_KEY=

# --- Database --------------------------------------------------------------
# Must match the passwords in init-db/01-init.sql (change BOTH for production).
POSTGRES_PASSWORD=ycode_pg_pw

# --- Ycode app (only needed for the containerised `app` profile) -----------
# Secret for signing page-auth cookies: openssl rand -hex 32
PAGE_AUTH_SECRET=please-change-this-page-auth-secret

# --- Realtime --------------------------------------------------------------
# REALTIME_SECRET_KEY_BASE: 64 hex chars -> `node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"`
# REALTIME_DB_ENC_KEY: exactly 16 chars.
REALTIME_SECRET_KEY_BASE=
REALTIME_DB_ENC_KEY=supabaserealtime

# --- Public URLs (override for a real domain in production) -----------------
# PUBLIC_API_URL = the gateway URL Ycode talks to (== SUPABASE_URL in Ycode's .env)
# SITE_URL       = the Ycode app URL (used in invite/reset email links)
# URI_ALLOW_LIST = redirect allow-list for auth emails (set to your SITE_URL in prod)
PUBLIC_API_URL=http://localhost:8000
SITE_URL=http://localhost:3002
URI_ALLOW_LIST=*

# --- Auth behaviour --------------------------------------------------------
# MAILER_AUTOCONFIRM=true skips email confirmation (fine locally; set false in prod).
# DISABLE_SIGNUP=true blocks public sign-up (invite-only). Recommended in prod.
MAILER_AUTOCONFIRM=true
DISABLE_SIGNUP=false

# --- SMTP (defaults point at the local Mailpit catcher) --------------------
# For production set these to your provider (see README "SMTP" section).
SMTP_HOST=mailpit
SMTP_PORT=1025
SMTP_USER=dev
SMTP_PASS=dev
SMTP_ADMIN_EMAIL=admin@ycode.local
SMTP_SENDER_NAME=Ycode
